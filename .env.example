# Environment Configuration
GOOGLE_API_KEY=your_gemini_api_key_here
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
A2A_SERVER_URL=http://localhost:8000/a2a

# Backend Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Agent Configuration
DEFAULT_MODEL=gemini-2.0-flash-001
MAX_PARALLEL_AGENTS=5
AGENT_TIMEOUT=30

# Memory Configuration
MEMORY_RETENTION_DAYS=30
CONTEXT_CAPTURE_INTERVAL=300  # 5 minutes

# Decision Paralysis Settings
DECISION_PARALYSIS_TIMEOUT=90  # seconds
FOOD_ORDER_COUNTDOWN=60  # seconds

# A2A Protocol Settings
A2A_CONNECTION_TIMEOUT=300  # 5 minutes
MAX_ACCOUNTABILITY_PARTNERS=5