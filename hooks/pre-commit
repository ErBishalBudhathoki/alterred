#!/usr/bin/env sh
set -eu

# Run TruffleHog on staged files only
if ! command -v trufflehog >/dev/null 2>&1; then
  echo "[pre-commit] trufflehog not found; install with 'brew install trufflehog' to enable secret scanning."
  exit 0
fi

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACM)"
if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo "[pre-commit] Running trufflehog on staged files..."
printf "%s\n" "$STAGED_FILES" | xargs trufflehog filesystem --fail --json --results verified || {
  echo "[pre-commit] Verified secret(s) detected. Commit aborted."
  exit 183
}
echo "[pre-commit] No verified secrets detected."